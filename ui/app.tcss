Screen {
    layout: vertical;
    background: #11141a;
    color: #fff8dc;
}

TextArea {
    border: none;
    background: transparent;
    color: #fff8dc;
}

TextArea:focus {
    border: none;
}

#output {
    height: 1fr;
    min-height: 12;
    padding: 1 2;
    background: #11141a;
}

#input {
    height: auto;
    min-height: 1;
    max-height: 6;
    border-top: solid #887dff;
    border-bottom: solid #887dff;
    background: #141820;
}
